# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/careerx?retryWrites=true&w=majority

# JWT Secrets (generate strong random strings)
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Client URL (for CORS and email links)
CLIENT_URL=http://localhost:3000

# Email (SMTP) — optional in development (uses Ethereal test account)
# In production, configure a real SMTP provider (SendGrid, Mailgun, AWS SES, etc.)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=your_sendgrid_api_key
# SMTP_FROM="CareerX" <noreply@careerx.dev>

# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here
